{
  "name": "dashboard-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Wrapper Electron do Dashboard de Produtividade — cliente fino, fala com o backend via config.json (apiBaseUrl)",
  "author": "Rezende Contabilidade Empresarial e Tributária",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-log": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.rezendecontabilidade.dashboard",
    "productName": "Dashboard Rezende",
    "artifactName": "${productName}-Setup-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "package.json",
      "app/**/*",
      "!app/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "devarya00",
      "repo": "conciliacao-web"
    }
  }
}
