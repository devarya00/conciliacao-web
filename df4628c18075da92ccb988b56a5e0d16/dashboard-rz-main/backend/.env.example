PORT=3001
# Postgres gerenciado (ex.: Neon) — exige SSL, tem prioridade sobre PGHOST/etc abaixo.
# Deixe vazio/comentado pra usar Postgres local (docker-compose), sem SSL.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=dashboard_produtividade
PGUSER=postgres
PGPASSWORD=postgres
INGESTAO_CRON=0 */2 * * *
INGESTAO_DIR=./data
JWT_SECRET=troque-por-um-segredo-forte-em-producao
JWT_EXPIRES_IN=8h
# origens web permitidas no CORS (separadas por vírgula); file:// (app desktop)
# manda Origin: null e já é liberado à parte, não precisa listar aqui
CORS_ALLOWED_ORIGINS=http://localhost:4200
