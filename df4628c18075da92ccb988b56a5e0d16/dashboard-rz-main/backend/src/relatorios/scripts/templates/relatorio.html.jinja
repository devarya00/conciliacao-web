<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<title>Relatório Gerencial — {{ empresa }} — {{ periodo_ini }} a {{ periodo_fim }}</title>
<style>
  :root{
    --ink:#0b0b0b; --ink-2:#52514e; --muted:#898781;
    --grid:#e1e0d9; --axis:#c3c2b7; --hairline:rgba(11,11,11,.10);
    --navy:#0d366b; --navy-2:#104281;
    --blue:#2a78d6; --red-bar:#e34948; --neg:#d03b3b; --pos:#006300;
    --wash:#f4f6fa;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{background:#fff}
  body{font-family:system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--ink);
       font-size:9.5pt;line-height:1.45;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  @page{size:A4;margin:0}
  .page{width:210mm;min-height:296.5mm;padding:0;page-break-after:always;position:relative;
        display:flex;flex-direction:column;overflow:hidden}
  .page:last-child{page-break-after:auto}
  .num{font-variant-numeric:tabular-nums}

  .band{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-2) 78%);color:#fff;
        padding:9mm 16mm 7mm}
  .band .kicker{font-size:8pt;letter-spacing:.22em;text-transform:uppercase;color:#9ec5f4;font-weight:600}
  .band h1{font-size:21pt;font-weight:700;letter-spacing:-.01em;margin:2mm 0 1mm}
  .band .sub{font-size:10.5pt;color:#cde2fb;font-weight:400}
  .metagrid{display:grid;grid-template-columns:repeat(4,1fr);gap:6mm;margin-top:4.5mm;
            border-top:1px solid rgba(255,255,255,.22);padding-top:3mm}
  .metagrid .lbl{font-size:6.8pt;letter-spacing:.14em;text-transform:uppercase;color:#86b6ef;font-weight:600}
  .metagrid .val{font-size:9.5pt;color:#fff;margin-top:.8mm}

  .content{padding:6.5mm 16mm 0;flex:1}
  .pagehead{padding:10mm 16mm 0}
  .pagehead .kicker{font-size:7.5pt;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);font-weight:600}
  .pagehead h2{font-size:15pt;font-weight:700;letter-spacing:-.01em;margin-top:1mm}
  .footer{padding:0 16mm 6mm;display:flex;justify-content:space-between;align-items:baseline;
          font-size:7.3pt;color:var(--muted)}
  .footer .rule{border-top:1px solid var(--grid);padding-top:3mm;width:100%;
                display:flex;justify-content:space-between;gap:6mm}
  .footer .rule span:last-child{white-space:nowrap}

  h3.sec{font-size:11pt;font-weight:700;margin:4mm 0 2.2mm;letter-spacing:-.005em}
  h3.sec:first-child{margin-top:0}
  .secnote{font-size:8pt;color:var(--ink-2);margin:-2mm 0 3mm}

  .kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:4mm;margin-top:0}
  .kpi{border:1px solid var(--grid);border-radius:3mm;padding:3.2mm 3.8mm;background:#fff}
  .kpi .lbl{font-size:7.2pt;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:600}
  .kpi .val{font-size:13.5pt;font-weight:700;letter-spacing:-.01em;margin-top:1.5mm}
  .kpi .cur{font-size:9pt;font-weight:600;color:var(--ink-2);margin-right:.5mm}
  .kpi .note{font-size:7.4pt;color:var(--ink-2);margin-top:1mm}
  .kpi.neg .val{color:var(--neg)}

  table{width:100%;border-collapse:collapse;font-size:9pt}
  th{font-size:7.2pt;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);
     font-weight:600;text-align:right;padding:1.6mm 2mm;border-bottom:1.5px solid var(--axis)}
  th:first-child{text-align:left;padding-left:0}
  td{padding:1.2mm 2mm;border-bottom:1px solid var(--grid);text-align:right;
     font-variant-numeric:tabular-nums}
  td:first-child{text-align:left;padding-left:0;font-variant-numeric:normal}
  tr.group td{font-weight:700;background:var(--wash)}
  tr.total td{font-weight:700;border-top:2px solid var(--axis);border-bottom:none;font-size:9.5pt}
  tr.sub td:first-child{padding-left:5mm;color:var(--ink-2)}
  td.neg{color:var(--neg)}
  .flagchip{display:inline-block;font-size:6.6pt;font-weight:700;letter-spacing:.06em;color:#8a5a00;
            background:#fdf0d5;border:1px solid #f3ddad;border-radius:2mm;padding:.2mm 1.6mm;
            vertical-align:1px;margin-left:1.5mm;text-transform:uppercase}

  .cols2{display:grid;grid-template-columns:1fr 1fr;gap:8mm}

  .chart{margin-top:2mm}
  .chart svg{display:block;width:100%;height:auto}
  .chart .cap{font-size:7.4pt;color:var(--muted);margin-top:1.5mm}
  .barlbl{font:600 8.6px system-ui,sans-serif;fill:var(--ink)}
  .barcat{font:400 8.6px system-ui,sans-serif;fill:var(--ink)}
  .barpct{font:400 8px system-ui,sans-serif;fill:#898781}
  .axisline{stroke:#c3c2b7;stroke-width:1}

  .callouts{display:flex;flex-direction:column;gap:3mm;margin-top:2mm}
  .callout{border:1px solid var(--grid);border-left:3px solid var(--blue);border-radius:2mm;
           padding:3.2mm 4mm;font-size:8.6pt}
  .callout.warn{border-left-color:#eda100}
  .callout.crit{border-left-color:var(--neg)}
  .callout b{display:block;font-size:9pt;margin-bottom:.6mm}
  .callout .tag{font-size:6.6pt;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
</style>
</head>
<body>

{% macro linha_tabela(row) -%}
<tr class="{{ row.kind }}">
  <td>{{ row.lbl }}{% if row.flag %}<span class="flagchip">{{ row.flag }}</span>{% endif %}</td>
  <td class="num{{ ' neg' if row.valor < 0 else '' }}">{{ row.valor | brl }}</td>
</tr>
{%- endmacro %}

<!-- ================================================================ PAGE 1 -->
<section class="page">
  <div class="band">
    <div class="kicker">Relatório Gerencial Contábil</div>
    <h1>{{ empresa }}</h1>
    <div class="sub">Análise do período {{ periodo_ini }} – {{ periodo_fim }}</div>
    <div class="metagrid">
      <div><div class="lbl">CNPJ</div><div class="val num">{{ cnpj }}</div></div>
      <div><div class="lbl">Período analisado</div><div class="val num">{{ periodo_ini }} – {{ periodo_fim }}</div></div>
      <div><div class="lbl">Fontes</div><div class="val">Balancete · Resumo por acumulador</div></div>
      <div><div class="lbl">Emissão dos dados</div><div class="val num">{{ emissao }}</div></div>
    </div>
  </div>

  <div class="content">
    <div class="kpis">
      {% for k in kpis %}
      <div class="kpi{{ ' neg' if k.neg else '' }}">
        <div class="lbl">{{ k.lbl }}</div>
        <div class="val num"><span class="cur">R$</span>{{ k.valor | brl }}</div>
        {% if k.nota %}<div class="note">{{ k.nota }}</div>{% endif %}
      </div>
      {% endfor %}
    </div>

    <h3 class="sec" style="margin-top:5.5mm">Demonstração do resultado do período <span style="font-weight:400;font-size:8pt;color:var(--muted)">— movimentações de {{ periodo_ini }} a {{ periodo_fim }}</span></h3>
    <table>
      <thead><tr><th>Linha</th><th style="width:30mm">Valor (R$)</th><th style="width:26mm">% receita líq.</th></tr></thead>
      <tbody>
        {% for row in dre_rows %}
        <tr class="{{ row.kind }}">
          <td>{{ row.lbl }}</td>
          <td class="num{{ ' neg' if row.valor < 0 else '' }}">{{ row.valor | brl }}</td>
          <td class="num">{{ row.pct | pct if row.pct is not none else '' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    {% if barras_receita %}
    <h3 class="sec">Receita × desembolsos do período</h3>
    <div class="chart">
      <svg viewBox="0 0 340 {{ altura_receita }}" style="max-width:118mm;margin:0 auto" role="img" aria-label="Barras horizontais de receita e desembolsos do período">
        <line class="axisline" x1="118" y1="4" x2="118" y2="{{ altura_receita - 4 }}"/>
        {% for b in barras_receita %}
        <g>
          <text class="barcat" x="114" y="{{ b.cat_y }}" text-anchor="end">{{ b.rotulo }}</text>
          <rect x="{{ b.x }}" y="{{ b.y }}" width="{{ b.largura }}" height="{{ b.altura }}" rx="{{ b.rx }}" fill="{{ b.cor }}"/>
          <text class="barlbl" x="{{ b.label_x }}" y="{{ b.cat_y }}" text-anchor="{{ b.label_anchor }}"{% if b.label_fill %} fill="{{ b.label_fill }}"{% endif %}>{{ b.valor_fmt }}</text>
        </g>
        {% endfor %}
      </svg>
      <div class="cap">{{ desembolsos_cap }}</div>
    </div>
    {% endif %}

    {% if acumulado_rows %}
    <h3 class="sec">Resultado acumulado do exercício (não encerrado)</h3>
    <p class="secnote">{{ acumulado_nota }}</p>
    <table>
      <thead><tr><th>Grupo</th><th style="width:34mm">Saldo acumulado (R$)</th></tr></thead>
      <tbody>
        {% for row in acumulado_rows %}{{ linha_tabela(row) }}{% endfor %}
      </tbody>
    </table>
    {% endif %}
  </div>

  <div class="footer"><div class="rule">
    <span>Rezende Contabilidade Empresarial e Tributária · dados extraídos do sistema Domínio</span>
    <span class="num">página 1 de 3</span>
  </div></div>
</section>

<!-- ================================================================ PAGE 2 -->
<section class="page">
  <div class="pagehead">
    <div class="kicker">{{ empresa }} · {{ periodo_ini }} – {{ periodo_fim }}</div>
    <h2>Balanço patrimonial &amp; fornecedores</h2>
  </div>

  <div class="content">
    <div class="cols2">
      <div>
        <h3 class="sec">Ativo — {{ periodo_fim }}</h3>
        <table>
          <thead><tr><th>Conta</th><th style="width:26mm">Saldo (R$)</th></tr></thead>
          <tbody>
            {% for row in ativo_rows %}{{ linha_tabela(row) }}{% endfor %}
          </tbody>
        </table>
      </div>
      <div>
        <h3 class="sec">Passivo e PL — {{ periodo_fim }}</h3>
        <table>
          <thead><tr><th>Conta</th><th style="width:26mm">Saldo (R$)</th></tr></thead>
          <tbody>
            {% for row in passivo_rows %}{{ linha_tabela(row) }}{% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {% if barras_fornecedores %}
    <h3 class="sec" style="margin-top:8mm">Fornecedores a pagar — {{ barras_fornecedores | length }} maiores saldos</h3>
    <p class="secnote">{{ fornecedores_nota }}</p>
    <div class="chart">
      <svg viewBox="0 0 340 {{ altura_fornecedores }}" role="img" aria-label="Barras horizontais dos maiores fornecedores">
        <line class="axisline" x1="141" y1="4" x2="141" y2="{{ altura_fornecedores - 4 }}"/>
        {% for b in barras_fornecedores %}
        <g>
          <text class="barcat" x="137" y="{{ b.cat_y }}" text-anchor="end">{{ b.rotulo }}</text>
          <rect x="{{ b.x }}" y="{{ b.y }}" width="{{ b.largura }}" height="{{ b.altura }}" rx="{{ b.rx }}" fill="{{ b.cor }}"/>
          <text class="barlbl" x="{{ b.label_x }}" y="{{ b.cat_y }}" text-anchor="{{ b.label_anchor }}"{% if b.label_fill %} fill="{{ b.label_fill }}"{% endif %}>{{ b.valor_fmt }}</text>
          <text class="barpct" x="{{ b.pct_x }}" y="{{ b.cat_y }}">{{ b.pct }}</text>
        </g>
        {% endfor %}
      </svg>
      {% if fornecedores_cap %}<div class="cap">{{ fornecedores_cap }}</div>{% endif %}
    </div>
    {% endif %}
  </div>

  <div class="footer"><div class="rule">
    <span>Rezende Contabilidade Empresarial e Tributária · dados extraídos do sistema Domínio</span>
    <span class="num">página 2 de 3</span>
  </div></div>
</section>

<!-- ================================================================ PAGE 3 -->
<section class="page">
  <div class="pagehead">
    <div class="kicker">{{ empresa }} · {{ periodo_ini }} – {{ periodo_fim }}</div>
    <h2>Movimento fiscal &amp; apontamentos</h2>
  </div>

  <div class="content">
    {% if fiscal_secoes %}
    <div class="cols2">
      {% for sec in fiscal_secoes %}
      <div>
        <h3 class="sec">{{ sec.nome }}</h3>
        <table>
          <thead><tr><th>Cód · Acumulador</th><th style="width:26mm">Vlr contábil (R$)</th></tr></thead>
          <tbody>
            {% for l in sec.linhas %}
            <tr><td><span class="num" style="color:var(--muted)">{{ l.codigo }}</span> · {{ l.descricao }}</td><td class="num">{{ l.valor | brl }}</td></tr>
            {% endfor %}
            <tr class="total"><td>Total {{ sec.nome.lower() }}</td><td class="num">{{ sec.total | brl }}</td></tr>
          </tbody>
        </table>
      </div>
      {% endfor %}
    </div>
    {% if fiscal_nota %}<p class="secnote" style="margin-top:3mm">{{ fiscal_nota }}</p>{% endif %}
    {% endif %}

    <h3 class="sec" style="margin-top:7mm">Apontamentos para regularização e gestão</h3>
    {% if callouts %}
    <div class="callouts">
      {% for c in callouts %}
      <div class="callout {{ c.nivel }}">
        <span class="tag">{{ c.tag }}</span>
        <b>{{ c.titulo }}</b>
        {{ c.corpo }}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p class="secnote">Nenhum apontamento crítico identificado neste período.</p>
    {% endif %}
  </div>

  <div class="footer"><div class="rule">
    <span>Relatório gerado por extração estruturada (SQLite) dos PDFs do Domínio</span>
    <span class="num">página 3 de 3</span>
  </div></div>
</section>

</body>
</html>
